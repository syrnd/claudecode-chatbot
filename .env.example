TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 白名单（必填）：填 Telegram user_id（逗号分隔）。留空时 bot 会拒绝启动（安全考虑）
ALLOWED_USER_IDS=

# Claude Code CLI 路径
CLAUDE_CMD=/home/sikim/.npm-global/bin/claude

# 单个任务最长执行时间（秒，默认 3600）
CLAUDE_TIMEOUT=3600

# 同时最多运行多少个 Claude 任务
MAX_CONCURRENT_TASKS=2

# 多少秒没有新活动后显示 quiet
TASK_QUIET_AFTER=180

# 多少秒没有新活动后显示 stalled（疑似卡住）
TASK_STALLED_AFTER=480

# 后台检查 stalled 的间隔（秒）
STALL_CHECK_INTERVAL=60

# 日志保留天数
TASK_LOG_RETENTION_DAYS=7

# 允许的工作目录前缀（限制 /workdir 命令可设置的路径范围）
ALLOWED_WORKDIR_PREFIX=/home/sikim/project

# 优先使用 1M（long）上下文版本（1=启用，0/false/no=禁用；不可用时自动回退标准版）
PREFER_LONG_CONTEXT=1
