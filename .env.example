TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 白名单：填 Telegram user_id（逗号分隔），留空则所有人可用
ALLOWED_USER_IDS=

# Claude Code CLI 路径
CLAUDE_CMD=/home/sikim/.npm-global/bin/claude

# 单个任务最长执行时间（秒）
CLAUDE_TIMEOUT=1800

# 同时最多运行多少个 Claude 任务
MAX_CONCURRENT_TASKS=2

# 多少秒没有新活动后显示 quiet
TASK_QUIET_AFTER=180

# 多少秒没有新活动后显示 stalled（疑似卡住）
TASK_STALLED_AFTER=480

# 后台检查 stalled 的间隔（秒）
STALL_CHECK_INTERVAL=60
